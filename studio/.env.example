# Liveblocks (required for workspace + canvas collab)
# Get from https://liveblocks.io/dashboard > API keys > secret key
LIVEBLOCKS_SECRET_KEY=sk_dev_xxx
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_dev_xxx

# URL of the local Claude bridge (defaults to ws://localhost:4456)
NEXT_PUBLIC_BRIDGE_URL=ws://localhost:4456

# Default workspace id (use one per team — anything URL-safe)
NEXT_PUBLIC_DEFAULT_WORKSPACE=oxflow-team
